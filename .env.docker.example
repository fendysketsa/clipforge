FRONTEND_PORT=3000
BACKEND_PORT=8010

# Browser-facing backend URL. Change this on a server, for example:
# NEXT_PUBLIC_API_BASE=https://api.your-domain.com
NEXT_PUBLIC_API_BASE=http://localhost:8010

# Private Telegram bot integration. Get the token from @BotFather and your
# numeric Telegram user ID from @userinfobot. Only this owner ID is accepted.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Optional public backend URL used only as a fallback link when a clip is over
# Telegram's upload limit. Leave empty for local-only deployments.
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_MAX_UPLOAD_MB=49
TELEGRAM_BATTERY_ALERT_ENABLED=true
TELEGRAM_BATTERY_ALERT_LEVELS=20,10,5
TELEGRAM_BATTERY_CHECK_INTERVAL_SECONDS=60
TELEGRAM_AI_BASE_URL=http://127.0.0.1:11434/v1
TELEGRAM_AI_MODEL=deepseek-v4-flash:cloud
TELEGRAM_AI_FALLBACK_MODELS=llama3:latest
YOUTUBE_REQUIRE_AI_METADATA=true
YOUTUBE_DATA_API_KEY=
VIRAL_CC_REQUIRE_YOUTUBE_DATA_API=true
# "|" berarti OR: setiap keyword dicari lalu kandidat terbaik digabungkan.
VIRAL_CC_SEARCH_QUERIES="podcast indonesia terbaru|podcast islam indonesia|kajian islam terbaru|ceramah terbaru indonesia|nasihat kehidupan islam|kisah inspiratif muslim|motivasi islami|rezeki dan sedekah|keluarga parenting islam|kesehatan mental islam|bisnis halal|hijrah indonesia|quran dan hadits"
# Gunakan 5 atau 7.
VIRAL_CC_VIDEO_COUNT=5
VIRAL_CC_SEARCH_LIMIT=25
VIRAL_CC_MAX_METADATA_CHECKS=200
VIRAL_CC_METADATA_PER_QUERY=6
VIRAL_CC_MIN_VIEWS=1000
VIRAL_CC_FALLBACK_MIN_VIEWS=100
VIRAL_CC_FALLBACK_MAX_AGE_DAYS=180
VIRAL_CC_MAX_API_QUERIES=12
VIRAL_CC_YTDLP_SEARCH_MODE=ytsearchdate
VIRAL_CC_MAX_SOURCE_SECONDS=7200
VIRAL_CC_SEARCH_HTTP_TIMEOUT_SECONDS=900
VIRAL_CC_REGION_CODE=ID
VIRAL_CC_RELEVANCE_LANGUAGE=id
VIRAL_CC_YOUTUBE_API_ORDER=viewCount
VIRAL_CC_TOPIC_ID=
VIRAL_CC_ENFORCE_TOPIC_ID=false
AUTO_VIRAL_SEARCH_QUERIES="podcast indonesia|dakwah|kajian|ceramah"
AUTO_VIRAL_VIDEO_COUNT=5
AUTO_VIRAL_MAX_SOURCE_SECONDS=7200

# Optional YouTube Studio uploader. Login once with:
# docker compose exec backend python youtube_uploader.py login
YOUTUBE_HEADLESS=true
# Login Sekali opens a visible Playwright browser on the host display and persists this dedicated profile.
YOUTUBE_DISPLAY=:1
YOUTUBE_HOST_RUNTIME_DIR=/run/user/1000
YOUTUBE_CHROMIUM_USER_DATA_DIR=/app/data/youtube-playwright-profile
YOUTUBE_CHROMIUM_PROFILE_DIRECTORY=Default
YOUTUBE_ALLOW_CHROMIUM_PROFILE_UPLOAD=false
YOUTUBE_CDP_URL=http://127.0.0.1:9222
YOUTUBE_UPLOAD_USE_CDP=false
YOUTUBE_UPLOAD_FORCE_CDP=false
YOUTUBE_UPLOAD_STORAGE_STATE_FIRST=true
YOUTUBE_UPLOAD_ALLOW_LAST_RESORT_FALLBACK=true
YOUTUBE_CDP_UPLOAD_REPAIR_ATTEMPTS=3
YOUTUBE_CDP_UPLOAD_MAX_ATTEMPTS=6
# Optional command used by the dashboard/Telegram "Run CDP" button.
# In Docker, ./scripts is mounted read-only at /app/scripts by docker-compose.yml.
# CDP is only needed for one-time cookie/session capture, not for every upload.
YOUTUBE_CDP_REFRESH_COMMAND=/app/scripts/open-youtube-login-chrome.sh
YOUTUBE_CDP_REFRESH_LOG=/tmp/clipforge-youtube-chrome-launcher.log
YOUTUBE_CDP_REFRESH_READY_TIMEOUT_SECONDS=30
TELEGRAM_YOUTUBE_CDP_REFRESH_TIMEOUT_SECONDS=60
TELEGRAM_YOUTUBE_ONE_TIME_LOGIN_TIMEOUT_SECONDS=180
YOUTUBE_ONE_TIME_LOGIN_PROFILE_TIMEOUT_SECONDS=90
YOUTUBE_ONE_TIME_LOGIN_ALLOW_CDP_FALLBACK=false
YOUTUBE_LOGIN_SOURCE_PROFILE_DIR=/app/data/youtube-playwright-profile
YOUTUBE_LOGIN_PROFILE_DIR=/app/data/youtube-playwright-profile
YOUTUBE_LOGIN_PROFILE_DIRECTORY=Default
YOUTUBE_CHROME_HEADLESS=false
YOUTUBE_LOGIN_HEADLESS=false
YOUTUBE_MAX_UPLOAD_MB=45
YOUTUBE_CDP_MAX_UPLOAD_MB=45
CLIP_MAX_MB=45
YOUTUBE_DEFAULT_VISIBILITY=public
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_DEFAULT_TAGS=
YOUTUBE_DEFAULT_PLAYLIST=Islam
YOUTUBE_TARGET_CHANNEL=ryuundyofficial
YOUTUBE_TARGET_EMAIL=fendysketsa@gmail.com
YOUTUBE_TARGET_CHANNEL_ID=UCAOZF9Qzj6DYoXKtLnP4UUQ
YOUTUBE_STUDIO_URL=https://studio.youtube.com/channel/UCAOZF9Qzj6DYoXKtLnP4UUQ
YOUTUBE_AUTO_UPLOAD_COUNT=3
YOUTUBE_REQUIRE_COPYRIGHT_CHECKS=true
YOUTUBE_CONTINUE_WHEN_CHECKS_STUCK=false
YOUTUBE_CHECKS_TIMEOUT_SECONDS=600
YOUTUBE_PRE_PUBLISH_REVIEW_TIMEOUT_SECONDS=300
YOUTUBE_RELOAD_AFTER_PUBLISH=true
YOUTUBE_RELOAD_AFTER_PUBLISH_DELAY_SECONDS=10
YOUTUBE_MANUAL_SUBTITLE_TEXT=FCN
YOUTUBE_ADD_MANUAL_SUBTITLE=true
YOUTUBE_SUBTITLE_TYPE_DELAY_MS=120
YOUTUBE_SUBTITLE_EDITOR_READY_DELAY_MS=1500
YOUTUBE_SUBTITLE_SEGMENT_READY_DELAY_MS=3000
YOUTUBE_SUBTITLE_AFTER_TYPE_DELAY_MS=500
YOUTUBE_SUBTITLE_ADD_TIMEOUT_MS=12000
YOUTUBE_SUBTITLE_MODE_TIMEOUT_MS=12000
YOUTUBE_SUBTITLE_TEXT_TIMEOUT_MS=20000
YOUTUBE_SUBTITLE_DONE_TIMEOUT_MS=12000
YOUTUBE_MANUAL_SUBTITLE_REQUIRED=true
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=900
YOUTUBE_STUDIO_NAV_TIMEOUT_MS=30000
YOUTUBE_DIRECT_UPLOAD_NAV_TIMEOUT_MS=18000
YOUTUBE_DIRECT_UPLOAD_INPUT_TIMEOUT_MS=15000
YOUTUBE_ALLOW_DIRECT_UPLOAD_PAGE_FALLBACK=true
YOUTUBE_DRY_RUN=false
YOUTUBE_CLOSE_UPLOAD_TAB=false
