FRONTEND_PORT=3000
BACKEND_PORT=8010

# Browser-facing backend URL. Change this on a server, for example:
# NEXT_PUBLIC_API_BASE=https://api.your-domain.com
NEXT_PUBLIC_API_BASE=http://localhost:8010

# Private Telegram bot integration. Get the token from @BotFather and your
# numeric Telegram user ID from @userinfobot. Only this owner ID is accepted.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Optional public backend URL used only as a fallback link when a clip is over
# Telegram's upload limit. Leave empty for local-only deployments.
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_MAX_UPLOAD_MB=49
YOUTUBE_STUDIO_URL=https://studio.youtube.com

# Optional YouTube Studio uploader. Login once with:
# docker compose exec backend python youtube_uploader.py login
YOUTUBE_HEADLESS=true
# Optional: reuse a Chromium/Chrome profile that is already logged in to YouTube.
# In Docker, this path must exist inside the backend container, for example via a bind mount.
YOUTUBE_CHROMIUM_HOST_USER_DATA_DIR=
YOUTUBE_CHROMIUM_USER_DATA_DIR=
YOUTUBE_CHROMIUM_PROFILE_DIRECTORY=Default
YOUTUBE_ALLOW_CHROMIUM_PROFILE_UPLOAD=false
YOUTUBE_CDP_URL=http://127.0.0.1:9222
YOUTUBE_DEFAULT_VISIBILITY=private
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_DEFAULT_TAGS=
YOUTUBE_DEFAULT_PLAYLIST=Islam
YOUTUBE_TARGET_CHANNEL=ryuundy8812
YOUTUBE_TARGET_EMAIL=fendysketsa@gmail.com
YOUTUBE_AUTO_UPLOAD_COUNT=3
YOUTUBE_REQUIRE_COPYRIGHT_CHECKS=true
YOUTUBE_CHECKS_TIMEOUT_SECONDS=300
YOUTUBE_DRY_RUN=false
